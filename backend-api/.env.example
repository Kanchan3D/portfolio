# Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster0.yq5fuwe.mongodb.net/portfolio

# CORS Origin (Frontend URL)
CORS_ORIGIN=http://localhost:5173

# Admin Key for authentication (must match frontend VITE_ADMIN_KEY)
# Used to secure POST/PUT/DELETE endpoints for content management
ADMIN_KEY=your-secret-admin-key-change-this

# Security Note: Keep ADMIN_KEY secret and never commit it to version control
# Use a strong, random key for production deployments
