# Frontend Environment Variables

# API Configuration
VITE_API_URL=http://localhost:5000/api

# EmailJS Configuration (Get these from your EmailJS account)
VITE_EMAILJS_SERVICE_ID=service_xxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Admin Key for content management (must match backend ADMIN_KEY)
VITE_ADMIN_KEY=your-secret-key-here

# Fallback CV URL (if backend CV fetch fails)
VITE_CV_URL=https://drive.google.com/file/d/1yzdrXJG6MOCjmjz1-GzCCpPxSefCiVT3/view

# Django Portfolio URL (for banner link)
VITE_DJANGO_PORTFOLIO_URL=https://your-django-portfolio.com
